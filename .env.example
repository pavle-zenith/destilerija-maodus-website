# ── Analytics (GA4) ───────────────────────────────────────────────
# Measurement ID. Leave empty to disable GA entirely (no banner scripts).
NEXT_PUBLIC_GA_ID=

# ── Sanity CMS ────────────────────────────────────────────────────
# From sanity.io/manage. Leave empty to run on the built-in content fallbacks.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Write token (Editor). Server-only — used to store form leads. Never NEXT_PUBLIC.
SANITY_API_WRITE_TOKEN=

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender, e.g. "Maoduš sajt <upiti@destilerijamaodus.rs>"
RESEND_FROM=
# Optional: newsletter audience id for footer signups
RESEND_AUDIENCE_ID=

# ── Spam protection (Cloudflare Turnstile) ────────────────────────
# Leave both empty to disable the widget + server check.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
